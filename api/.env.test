# =============================================================================
# Variables d'environnement pour les tests
# =============================================================================
# Utilise une base de données séparée pour ne pas polluer la base de dev.
# =============================================================================

APP_ENV=test
APP_SECRET=test_secret_not_for_production

# Base de données de test (suffixe _test)
DATABASE_URL="postgresql://yapuka:yapuka@database:5432/yapuka_test?serverVersion=16&charset=utf8"

# Redis de test
REDIS_URL=redis://redis:6379/1

DEFAULT_URI=http://localhost:8080

# JWT (mêmes clés que dev pour les tests)
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=38def647126dce3a19fdb5c6bccfe6b0ebb2db31554093018c9de694a1362252

# CORS
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
