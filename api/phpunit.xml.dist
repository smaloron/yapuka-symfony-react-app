<?xml version="1.0" encoding="UTF-8"?>
<!-- =============================================================================
     Configuration PHPUnit pour Yapuka API
     =============================================================================
     Exécution de tous les tests : php bin/phpunit
     Tests unitaires seuls :      php bin/phpunit tests/Unit
     Tests d'intégration seuls :  php bin/phpunit tests/Integration
     ============================================================================= -->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         backupGlobals="false"
         colors="true"
         bootstrap="tests/bootstrap.php"
>
    <php>
        <ini name="display_errors" value="1"/>
        <ini name="error_reporting" value="-1"/>
        <!-- Forcer l'environnement de test -->
        <server name="APP_ENV" value="test" force="true"/>
        <server name="SHELL_VERBOSITY" value="-1"/>
        <server name="KERNEL_CLASS" value="App\Kernel"/>
    </php>

    <testsuites>
        <!-- Suite de tests unitaires (rapides, sans base de données) -->
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <!-- Suite de tests d'intégration (avec base de données) -->
        <testsuite name="Integration">
            <directory>tests/Integration</directory>
        </testsuite>
    </testsuites>

    <!-- Couverture de code (optionnel, nécessite Xdebug) -->
    <source>
        <include>
            <directory suffix=".php">src</directory>
        </include>
    </source>
</phpunit>
