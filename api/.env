# =============================================================================
# Yapuka API - Variables d'environnement
# =============================================================================
# Ce fichier contient les valeurs par défaut pour le développement.
# Ne JAMAIS commiter de secrets en production.
# Créer un fichier .env.local pour surcharger ces valeurs.
# =============================================================================

# --- Environnement Symfony ---
APP_ENV=dev
APP_SECRET=yapuka_change_this_secret_in_production

# --- Base de données PostgreSQL ---
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE?serverVersion=VERSION
DATABASE_URL="postgresql://yapuka:yapuka@database:5432/yapuka?serverVersion=16&charset=utf8"

# --- JWT (Lexik) ---
# Chemin vers les clés RSA pour signer les tokens JWT
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=yapuka_jwt_passphrase

# --- Redis (Cache) ---
REDIS_URL=redis://redis:6379

# --- CORS ---
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
