# =============================================================================
# Variables d'environnement frontend (Vite)
# =============================================================================
# Les variables préfixées par VITE_ sont accessibles dans le code JavaScript
# via import.meta.env.VITE_NOM_VARIABLE
# =============================================================================

# URL de base de l'API backend
# En développement avec Docker, le proxy Nginx redirige /api vers PHP
VITE_API_URL=http://localhost:8080
